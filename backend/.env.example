# Copy to .env and fill in. Free tokens — no card needed.

# WAQI air-quality token: https://aqicn.org/data-platform/token/
WAQI_TOKEN=

# Groq free tier (Llama 3.3 70B): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallback air source: https://openweathermap.org/api/air-pollution
OPENWEATHER_KEY=

# Cache TTLs (seconds) — fine to leave as-is
AQI_TTL=300
PLAN_TTL=600
CACHE_DB=saafhawa.db
